{
  "manifest_version": 3,
  "name": "FunPay Automation Tool",
  "version": "2.3.1",
  "description": "Авто-поднятие объявлений и управляемый мультипостинг для FunPay.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://funpay.com/*",
    "https://*.funpay.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://funpay.com/lots/offer*",
        "https://*.funpay.com/lots/offer*"
      ],
      "js": [
        "content/shared.js",
        "content/form-adapter.js",
        "content/offer-client.js",
        "content/multipost-view.js",
        "content/multipost-controller.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FunPay Automation Tool"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
